# ──────────────────────────────────────────────────────────────────────────────
#  Backend production env — copy to backend/.env on the VPS, fill in real values.
#  NEVER commit this file with real secrets.
#
#  cp deploy/env.backend.example backend/.env
#  nano backend/.env
# ──────────────────────────────────────────────────────────────────────────────

NODE_ENV=production
PORT=5000

# MongoDB — Docker container is on localhost, root creds set in deploy/.env
# (see deploy/docker-compose.mongo.yml). Replace USER and PASS to match.
MONGODB_URI=mongodb://USER:PASS@127.0.0.1:27017/medstore?authSource=admin

# JWT — generate one with: openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# CORS — comma-separated. Use your domain when you have one; for IP-only
# deployment list http://<vps-ip>. Don't use '*' in production.
CORS_ORIGIN=http://YOUR_VPS_IP_OR_DOMAIN

# Cookies — set to true once you have HTTPS via Certbot
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# Optional: superadmin bootstrap (used by seed script if present)
SEED_SUPERADMIN_EMAIL=superadmin@medstore.com
SEED_SUPERADMIN_PASSWORD=admin123456

# ──────────────────────────────────────────────────────────────────────────────
#  MongoDB container env — copy to deploy/.env on the VPS, fill in real values.
#  Used by deploy/docker-compose.mongo.yml.
#
#  cp deploy/env.mongo.example deploy/.env
#  nano deploy/.env
#
#  Generate a strong password:
#    openssl rand -base64 24 | tr -d '/+='
# ──────────────────────────────────────────────────────────────────────────────

MONGO_USER=medstore_admin
MONGO_PASS=CHANGE_ME_TO_A_STRONG_PASSWORD

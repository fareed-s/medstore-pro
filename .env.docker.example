# ──────────────────────────────────────────────────────────────────────────────
#  MedStore Pro — Docker stack env
#
#  cp .env.docker.example .env
#  nano .env       # fill in real values
#
#  Then: docker compose up -d --build
# ──────────────────────────────────────────────────────────────────────────────

# ─── MongoDB ────────────────────────────────────────────────────────────────
# Generate a strong password:  openssl rand -base64 24 | tr -d '/+='
MONGO_USER=medstore_admin
MONGO_PASS=CHANGE_ME_TO_A_STRONG_PASSWORD
MONGO_DB=medstore-pro

# ─── Backend ────────────────────────────────────────────────────────────────
# Generate:  openssl rand -base64 48
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING
JWT_EXPIRES_IN=7d

# Frontend URL the browser will load. For IP-only deployment use http://VPS_IP:WEB_PORT.
# When you put a domain in front via ep-nginx, change this to https://yourdomain.com
# and set COOKIE_SECURE=true.
CORS_ORIGIN=http://YOUR_VPS_IP:8085

COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ─── Bootstrap superadmin (used by seeds/index.js on fresh DB) ─────────────
SEED_SUPERADMIN_EMAIL=superadmin@medstore.com
SEED_SUPERADMIN_PASSWORD=admin123456

# ─── Public port ────────────────────────────────────────────────────────────
# Pick a free port on the VPS. Existing apps use 8082-8084 → 8085 is free.
WEB_PORT=8085
